# ============================================================
# Variáveis de ambiente do frontend (Vite)
# ============================================================
# Valores PÚBLICOS (anon key + URL do Supabase) ficam em .env.production
# (commitado no repo — Vite injeta no bundle durante `vite build` no Lovable).
#
# Valores LOCAIS (overrides de dev) ficam em .env ou .env.local (gitignored).
#
# Edge function secrets (META_CAPI_ACCESS_TOKEN, SUPABASE_SERVICE_ROLE_KEY,
# etc.) são gerenciados pelo Lovable Cloud → Manage Secrets, NÃO neste arquivo.
# ============================================================

VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""
